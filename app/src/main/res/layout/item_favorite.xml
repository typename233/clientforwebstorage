<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="68dp"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="7dp"
    android:paddingEnd="14dp"
    android:paddingBottom="7dp">

    <CheckBox
        android:id="@+id/checkbox_select"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="10dp"
        android:visibility="gone"
        android:buttonTint="@color/primary_blue" />

    <ImageView
        android:id="@+id/iv_favorite_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="文件图标" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_favorite_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_favorite_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_unfavorite"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginEnd="6dp"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_unfavorite_button"
        android:text="取消收藏"
        android:textColor="#D32F2F"
        android:textSize="12sp"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/btn_more"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="⋮"
        android:textColor="#8A8A8A"
        android:textSize="20sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="更多操作" />

</LinearLayout>
