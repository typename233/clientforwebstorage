<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/menu_pin_group"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="置顶群组"
        android:textSize="15sp"
        android:textColor="#333333"
        android:background="?attr/selectableItemBackground" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E0E0E0" />

    <TextView
        android:id="@+id/menu_edit_group"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="编辑群组信息"
        android:textSize="15sp"
        android:textColor="#333333"
        android:background="?attr/selectableItemBackground" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E0E0E0" />

    <TextView
        android:id="@+id/menu_manage_members"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="成员管理"
        android:textSize="15sp"
        android:textColor="#333333"
        android:background="?attr/selectableItemBackground" />

    <View
        android:id="@+id/divider_transfer"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E0E0E0" />

    <TextView
        android:id="@+id/menu_transfer_ownership"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="转让群主"
        android:textSize="15sp"
        android:textColor="#333333"
        android:background="?attr/selectableItemBackground" />

    <View
        android:id="@+id/divider_mute"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E0E0E0" />

    <TextView
        android:id="@+id/menu_mute_notifications"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="消息免打扰"
        android:textSize="15sp"
        android:textColor="#333333"
        android:background="?attr/selectableItemBackground" />

    <View
        android:id="@+id/divider_dissolve"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E0E0E0" />

    <TextView
        android:id="@+id/menu_dissolve_group"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="解散群组"
        android:textSize="15sp"
        android:textColor="#FF5252"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>
