    "/api/v1/shares": {
      "post": {
        "tags": [
          "Share"
        ],
        "summary": "创建分享",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "resourceIds"
                ],
                "properties": {
                  "resourceIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "expiredAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "needCode": {
                    "type": "boolean"
                  },
                  "code": {
                    "type": "string"
                  },
                  "allowPreview": {
                    "type": "boolean",
                    "default": true
                  },
                  "allowDownload": {
                    "type": "boolean",
                    "default": true
                  },
                  "maxAccessCount": {
                    "type": "integer",
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
