        ],
        "summary": "上传分片（二进制）",
        "parameters": [
          {
            "$ref": "#/components/parameters/UploadId"
          },
          {
            "$ref": "#/components/parameters/PartNumber"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
