    "/api/v1/uploads/init": {
      "post": {
        "tags": [
          "Upload"
        ],
        "summary": "初始化上传会话",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "filename",
                  "size",
                  "partSize"
                ],
                "properties": {
                  "parentId": {
                    "type": "string",
                    "nullable": true
                  },
                  "filename": {
                    "type": "string"
                  },
                  "size": {
                    "type": "integer",
                    "format": "int64"
                  },
                  "sha256": {
                    "type": "string"
                  },
                  "partSize": {
                    "type": "integer",
                    "format": "int64"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
