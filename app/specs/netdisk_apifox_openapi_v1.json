{
  "openapi": "3.0.3",
  "info": {
    "title": "NetDisk API (Phase 1, Web + Android)",
    "version": "1.0.0",
    "description": "网盘项目一期接口定义（无管理员后台），适用于 Apifox/Swagger 导入。\n统一支持 Web 与 Android 客户端。\n"
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Production"
    },
    {
      "url": "https://staging-api.example.com",
      "description": "Staging"
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Space"
    },
    {
      "name": "Resource"
    },
    {
      "name": "Upload"
    },
    {
      "name": "Share"
    },
    {
      "name": "SharePublic"
    },
    {
      "name": "Permission"
    },
    {
      "name": "Activity"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "注册（显式字段：email/mobile）",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "email",
                      "password",
                      "nickname"
                    ],
                    "properties": {
                      "email": {
                        "type": "string",
                        "format": "email",
                        "example": "user@example.com"
                      },
                      "password": {
                        "type": "string",
                        "format": "password"
                      },
                      "nickname": {
                        "type": "string",
                        "example": "Tom"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "required": [
                      "mobile",
                      "password",
                      "nickname"
                    ],
                    "properties": {
                      "mobile": {
                        "type": "string",
                        "example": "13800138000"
                      },
                      "password": {
                        "type": "string",
                        "format": "password"
                      },
                      "nickname": {
                        "type": "string",
                        "example": "Tom"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "登录（显式字段：email/mobile）",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "email",
                      "password",
                      "clientType"
                    ],
                    "properties": {
                      "email": {
                        "type": "string",
                        "format": "email",
                        "example": "user@example.com"
                      },
                      "password": {
                        "type": "string",
                        "format": "password"
                      },
                      "clientType": {
                        "type": "string",
                        "enum": [
                          "web",
                          "android"
                        ]
                      },
                      "deviceId": {
                        "type": "string",
                        "example": "android-123456"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "required": [
                      "mobile",
                      "password",
                      "clientType"
                    ],
                    "properties": {
                      "mobile": {
                        "type": "string",
                        "example": "13800138000"
                      },
                      "password": {
                        "type": "string",
                        "format": "password"
                      },
                      "clientType": {
                        "type": "string",
                        "enum": [
                          "web",
                          "android"
                        ]
                      },
                      "deviceId": {
                        "type": "string",
                        "example": "android-123456"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "accessToken": {
                              "type": "string"
                            },
                            "refreshToken": {
                              "type": "string"
                            },
                            "expiresIn": {
                              "type": "integer",
                              "example": 7200
                            },
                            "user": {
                              "$ref": "#/components/schemas/UserProfile"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "刷新 Access Token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "refreshToken"
                ],
                "properties": {
                  "refreshToken": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
